# dependencies
node_modules
apps/mobile/node_modules

# build outputs
.next
out
build
dist
coverage
.turbo
*.tsbuildinfo

# local native artifacts
apps/mobile/android
apps/mobile/ios
apps/mobile/.expo
apps/mobile/ios/build

# local QA / screenshots
qa-artifacts
.maestro
qa
# Loose screenshots at the repo root only — do NOT recursively exclude PNGs,
# otherwise required runtime assets like apps/mobile/assets/*.png are dropped
# from the EAS upload and Metro can't resolve them at bundle time.
/*.png
/*.jpg
/*.jpeg

# local tooling
.git
.vercel
.clerk
# Claude Code: worktrees (checkouts completos del repo) + snapshots, ~6 GB.
# NO lo necesita el build; sin esto el archivo pasa de 2.0 GB (límite EAS).
.claude
# Scratch de generación de contenido (audio, venv de Python, sets), ~4 GB.
# El bundle mobile no importa nada de scripts/.
scripts
.expo

# misc
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# generated / local-only files
src/generated/prisma
android-twa
public
