{
  "name": "digital-polyglot-library",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "prisma generate && next dev",
    "dev:web": "next dev",
    "dev:mobile": "npm run start --prefix apps/mobile",
    "build": "prisma generate && next build",
    "ios": "npm run ios --prefix apps/mobile",
    "start": "next start",
    "lint": "next lint",
    "qa:ux:web:capture": "tsx scripts/captureWebScreenshots.ts",
    "qa:ux:studio:capture": "QA_SCREENSHOT_CONFIG=qa/studio-screenshots.config.json tsx scripts/captureWebScreenshots.ts",
    "qa:ux:audit": "tsx scripts/uxAudit.ts",
    "qa:ux:audit:fix": "tsx scripts/uxAudit.ts --fix",
    "qa:mobile:interaction:preview": "echo 'maestro test .maestro/qa-interaction-preview.yaml'",
    "qa:mobile:interaction:auth": "echo 'maestro test .maestro/qa-interaction-authenticated.yaml'",
    "media:upload-catalog": "tsx scripts/uploadCatalogMediaToObjectStorage.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@clerk/backend": "^2.17.2",
    "@clerk/nextjs": "^6.33.0",
    "@prisma/client": "^6.17.1",
    "@sentry/nextjs": "^10.53.1",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.544.0",
    "next": "^15.5.7",
    "openai": "^5.23.2",
    "pg": "^8.16.3",
    "prisma": "^6.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.3.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "resend": "^6.1.3",
    "slugify": "^1.6.6",
    "stripe": "^19.1.0",
    "styled-components": "^6.1.19",
    "svix": "^1.80.0",
    "unified": "^11.0.5",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/recharts": "^1.8.29",
    "@types/turndown": "^5.0.6",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "turndown": "^7.2.4",
    "typescript": "^5.9.3",
    "vercel": "^50.32.5"
  }
}
