{
  "name": "digital-polyglot-library",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "prisma generate && next dev",
    "dev:web": "next dev",
    "dev:mobile": "npm run start --workspace @digital-polyglot/mobile",
    "dev:studio": "sanity dev --host",
    "build": "prisma generate && next build",
    "postinstall": "node scripts/patchClerkExpo.js",
    "ios": "npm run ios --workspace @digital-polyglot/mobile",
    "start": "next start",
    "lint": "next lint",
    "qa:ux:web:capture": "tsx scripts/captureWebScreenshots.ts",
    "qa:ux:studio:capture": "QA_SCREENSHOT_CONFIG=qa/studio-screenshots.config.json tsx scripts/captureWebScreenshots.ts",
    "qa:ux:audit": "tsx scripts/uxAudit.ts",
    "qa:ux:audit:fix": "tsx scripts/uxAudit.ts --fix",
    "qa:mobile:interaction:preview": "echo 'maestro test .maestro/qa-interaction-preview.yaml'",
    "qa:mobile:interaction:auth": "echo 'maestro test .maestro/qa-interaction-authenticated.yaml'",
    "import:sanity": "tsx scripts/importBooks.ts",
    "export:sanity": "tsx scripts/exportBooksFromSanity.ts",
    "media:upload-catalog": "tsx scripts/uploadCatalogMediaToObjectStorage.ts",
    "media:backfill-standalone": "tsx scripts/backfillStandaloneStoryMedia.ts",
    "media:backfill-polyglot": "tsx scripts/backfillPolyglotStoryMedia.ts",
    "media:reconcile-create-story-assets": "tsx scripts/reconcileCreateStoryMediaFromSanityAssets.ts",
    "sync:create-stories": "tsx scripts/syncCreateStoriesToSanity.ts",
    "sync:create-stories:cli": "sanity exec scripts/syncCreateStoriesToSanity.ts --with-user-token",
    "sync:create-story-slugs": "tsx scripts/syncCreateStorySlugs.ts",
    "repair:create-story-drafts": "sanity exec scripts/repairCreateStoryDrafts.ts --with-user-token",
    "tag:polyglot-stories": "tsx scripts/tagPolyglotStories.ts",
    "reset:polyglot-stories": "tsx scripts/resetPolyglotStoriesVisibility.ts"
  },
  "dependencies": {
    "@clerk/backend": "^2.17.2",
    "@clerk/nextjs": "^6.33.0",
    "@prisma/client": "^6.17.1",
    "@sanity/client": "^7.12.0",
    "@sanity/image-url": "^1.2.0",
    "@sanity/vision": "^4.10.2",
    "@sentry/browser": "^10.22.0",
    "@sentry/nextjs": "^10.22.0",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "groq": "^4.10.2",
    "lucide-react": "^0.544.0",
    "next": "^15.5.7",
    "next-sanity": "^11.4.2",
    "@anthropic-ai/sdk": "^0.80.0",
    "openai": "^5.23.2",
    "pg": "^8.16.3",
    "prisma": "^6.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.3.0",
    "resend": "^6.1.3",
    "sanity": "^4.10.2",
    "slugify": "^1.6.6",
    "stripe": "^19.1.0",
    "styled-components": "^6.1.19",
    "svix": "^1.80.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/recharts": "^1.8.29",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vercel": "^50.32.5"
  }
}
