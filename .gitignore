# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/apps/mobile/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist
/apps/mobile/android
/apps/mobile/ios

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.keystore
*.keystore
android-twa/.keystore-secrets.local
android-twa/.gradle/
android-twa/**/build/
android-twa/app-release-*.aab
android-twa/app-release-*.apk
android-twa/app-release-*.idsig

# google play service account key (eas submit --platform android).
# Da acceso de escritura a Play Console; nunca commitear.
.secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

/src/generated/prisma

# Sentry Config File
.env.sentry-build-plugin

# Piper TTS voice models (download via scripts/tts/download_piper_voices.sh)
scripts/tts/piper-voices/
# Python virtualenvs used by the TTS pipeline (recreated via scripts/tts/setup.sh
# or per-engine extras for Chatterbox / Qwen3 etc.). All variants must be
# ignored, otherwise multi-hundred-MB libtorch / llvmlite blobs get committed
# and rejected by GitHub's 100 MB limit.
scripts/tts/.venv/
scripts/tts/.venv-*/
# F5 cloned voice WAVs (per-user data, sourced manually)
scripts/tts/cloned-voices/
# Whisper.cpp ggml models (~465 MB, downloaded via scripts/tts/setup.sh)
scripts/tts/whisper-models/
# Claude Code runtime artifacts
.claude/scheduled_tasks.lock
data/vocab-shorten/

# Safety guard runtime files (snapshots live outside repo)
.claude/safety/audit.log
.claude/safety/env-snapshots/

# throwaway debug scripts / empty stubs
_keys.mts
/app.json
.env*.local
