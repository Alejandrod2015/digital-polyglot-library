}

model Favorite {
  id              String    @id @default(cuid())
  userId          String
  word            String
  translation     String
  wordType        String?
  exampleSentence String?
  storySlug       String?
  storyTitle      String?
  sourcePath      String?
  language        String?
  createdAt       DateTime  @default(now())
  nextReviewAt    DateTime?
  lastReviewedAt  DateTime?
  streak          Int       @default(0)

  @@unique([userId, word], name: "userId_word")
  @@index([userId])
}

// User-defined favorite collections. Same shape as the mobile-side
// `FavoriteCollection` (apps/mobile/src/mobile/collections.ts) so iPhone
// can sync via this table in a future migration. Each `wordKeys` entry
// is `${language}::${word}` lowercased — matches `collectionWordKey()`.
model FavoriteCollection {
  id        String   @id @default(cuid())
  userId    String
  name      String
  /** Canonical language name ("Spanish", "German", ...). Optional for
   *  backward compat with collections created without a language tag. */
  language  String?
  /** "${language}::${word}" lowercased entries. */
  wordKeys  String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("dp_favorite_collections_v1")
}

model VerbConjugation {
  id         String   @id @default(cuid())
  language   String
  infinitive String
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([language, infinitive])
  @@index([language])
}

model LibraryBook {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  title     String
  coverUrl  String
  createdAt DateTime @default(now())

  @@unique([userId, bookId], name: "userId_bookId")
  @@index([userId])
}

model LibraryStory {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  title     String
  coverUrl  String
  bookId    String
  createdAt DateTime @default(now())

  @@unique([userId, storyId], name: "userId_storyId")
  @@index([userId])
}

// Word-level audio alignments for stories that live in the static
// catalog (`src/data/books/*.ts`), generated via Modal/aeneas (the same
// pipeline that powers `JourneyStory.audioWordTimings`). Stored by slug
// because the catalog is TS-static — there is no parent table to
// extend. Populated by `scripts/generateCatalogAudioTimings.ts`; served
// by `/api/mobile/audio-word-timings` when the journey lookup misses.
model CatalogStoryAudioTimings {
  slug              String   @id
  audioWordTimings  Json
  audioDurationSec  Float?
  updatedAt         DateTime @updatedAt
}

// Beta tester applications. Public form at /beta writes here; admin reviews
// at /studio/beta-signups and triggers TestFlight invites manually in App
// Store Connect. `status` lifecycle: pending -> invited -> accepted | declined.
model BetaSignup {
  id                String    @id @default(cuid())
  email             String    @unique
  nativeLanguage    String
  targetLanguage    String
  currentLevel      String
  hasIPhone         Boolean
  currentApps       String?
  weeklyHours       String?
  referralSource    String?
  // New required fields (added 2026-05-17). Existing rows pre-migration
  // will have these NULL; the form going forward requires them.
  motivation        String?
  applicationReason String?
  // Silent attribution captured from the browser at form mount:
  // utm_source/medium/campaign/content/term, document.referrer, and the
  // landing URL the visitor first arrived at. Lets us source traffic
  // without asking.
  attribution       Json?
  consentedAt       DateTime
  status            String    @default("pending")
  notes             String?
  invitedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("dp_beta_signups_v1")
}

// One row per page view. Server-side, cookie-less, GDPR-friendly:
// no PII, only hashed IP (sha256 + salt, truncated to /24) and a
// rotating session cookie. Captures geo from Vercel edge headers and
// UTM/referrer/landing from the client. Lets us answer "where did
// this visit come from?" for 100% of visitors regardless of analytics
// consent, since this is first-party telemetry necessary for site
// operation (debugging, abuse prevention, capacity planning).
model PageVisit {
  id              String   @id @default(cuid())
  path            String
  referrer        String?
  landingUrl      String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  country         String?
  region          String?
  city            String?
  timezone        String?
  browserLanguage String?
  deviceCategory  String?
  userAgent       String?
  // sha256(rawIp + APP_SECRET) truncated to /24 worth of entropy.
  // Lets us count uniques without ever storing a recoverable IP.
  ipHashed        String?
  // Random opaque ID stored in a httpOnly first-party cookie. Survives
  // ~30 min of inactivity. Strictly necessary cookie, no consent needed.
  sessionId       String?
  // Whether this row was logged before the user accepted analytics.
  // Useful if we ever want to retroactively scrub pre-consent data.
  preConsent      Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([sessionId])
  @@index([country])
  @@index([utmSource])
  @@map("dp_page_visits_v1")
}

