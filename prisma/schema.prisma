generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudioRole {
  admin
  manager
  content_creator
}

enum AgentKind {
  curriculum
  planner
  content
  qa
  translation
}

enum AgentRunStatus {
  queued
  running
  completed
  failed
  needs_review
}

enum AgentArtifactStatus {
  draft
  generated
  qa_pass
  qa_fail
  needs_review
  approved
  published
}

model Topic {
  id           String   @id @default(cuid())
  slug         String   @unique
  label        String
  isUniversal  Boolean  @default(true)
  defaultLevel String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journeyTypes TopicJourneyType[]

  @@index([sortOrder])
  @@map("dp_topics_v1")
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants LanguageVariant[]

  @@index([sortOrder])
  @@map("dp_languages_v1")
}

model LanguageVariant {
  id         String   @id @default(cuid())
  languageId String
  code       String
  label      String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([languageId, code])
  @@index([languageId])
  @@map("dp_language_variants_v1")
}

model Level {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("dp_levels_v1")
}

model JourneyType {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics TopicJourneyType[]

  @@index([sortOrder])
  @@map("dp_journey_types_v1")
}

model TopicJourneyType {
  id            String   @id @default(cuid())
  topicId       String
  journeyTypeId String
  createdAt     DateTime @default(now())

  topic       Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  journeyType JourneyType @relation(fields: [journeyTypeId], references: [id], onDelete: Cascade)

  @@unique([topicId, journeyTypeId])
  @@index([topicId])
  @@index([journeyTypeId])
  @@map("dp_topic_journey_types_v1")
}

model StudioMember {
  id        String     @id @default(cuid())
  email     String     @unique
  role      StudioRole
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("dp_studio_members")
}

model AgentRun {
  id           String         @id @default(cuid())
  agentKind    AgentKind
  status       AgentRunStatus @default(queued)
  model        String?
  input        Json
  output       Json?
  errorMessage String?
  toolsUsed    String[]
  parentRunId  String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([agentKind, status, createdAt])
  @@index([parentRunId])
  @@map("dp_agent_runs_v1")
}

model CurriculumBrief {
  id           String              @id @default(cuid())
  language     String
  variant      String
  level        String
  journeyKey   String
  topicSlug    String
  storySlot    Int
  journeyFocus String?             @default("General")
  title        String
  brief        Json
  status       AgentArtifactStatus @default(draft)
  sourceRunId  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([language, variant, level])
  @@index([journeyKey, topicSlug, storySlot])
  @@index([status])
  @@map("dp_curriculum_briefs_v1")
}

model StoryDraft {
  id            String              @id @default(cuid())
  briefId       String?
  sourceStoryId String?
  title         String
  slug          String?
  text          String
  synopsis      String?
  vocab         Json?
  metadata      Json?
  status        AgentArtifactStatus @default(draft)
  sourceRunId   String?
  latestQaRunId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([briefId])
  @@index([sourceStoryId])
  @@index([status])
  @@map("dp_story_drafts_v1")
}

model QAReview {
  id             String   @id @default(cuid())
  storyDraftId   String?
  sourceStoryId  String?
  sourceRunId    String?
  status         String
  score          Float?
  report         Json
  correctedText  String?
  correctedVocab Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([storyDraftId])
  @@index([sourceStoryId])
  @@index([status, createdAt])
  @@map("dp_qa_reviews_v1")
}

enum JourneyStatus {
  active
  completed
  archived
}

model ClonedVoice {
  id           String   @id @default(cuid())
  name         String
  language     String
  region       String?
  gender       String   @default("f")
  refAudioPath String
  refText      String
  createdBy    String?
  createdAt    DateTime @default(now())

  @@index([language])
  @@map("dp_cloned_voices_v1")
}

model Journey {
  id              String        @id @default(cuid())
  name            String
  language        String
  variant         String
  levels          String[]
  topics          String[]
  storiesPerTopic Int           @default(1)
  status          JourneyStatus @default(active)
  createdBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  stories JourneyStory[]

  @@index([status])
  @@index([language, variant])
  @@map("dp_journeys_v1")
}

model JourneyStory {
  id                   String              @id @default(cuid())
  journeyId            String
  level                String
  topic                String
  slotIndex            Int
  status               AgentArtifactStatus @default(draft)
  title                String?
  slug                 String?
  text                 String?
  synopsis             String?
  vocab                Json?
  wordCount            Int?
  vocabCount           Int?
  arcType              String?
  // Dialect / heritage-learner asset metadata. All optional; backfilled by
  // the editorial workflow as content is tagged. Foundation for filtering
  // the corpus by register, cohort, or cultural variant.
  register             String[]            @default([])
  generationCohort     String?
  culturalTags         String[]            @default([])
  voiceProvenance      Json?
  sanityId             String?
  coverDone            Boolean             @default(false)
  coverUrl             String?
  audioUrl             String?
  audioSegments        Json?
  audioWordTimings     Json?
  audioFilename        String?
  audioStatus          String              @default("pending")
  audioUrlPreview      String?
  audioFilenamePreview String?
  ambientTag           String?
  voiceId              String?
  dialogueSpec         Json?
  audioQaStatus        String?
  audioQaScore         Float?
  audioQaNotes         String?
  // Vocabulary-level audit (LLM-as-judge against story.level CEFR).
  // Cleared whenever text is regenerated; refilled by /audit-level.
  auditScore           Float?
  auditOffenders       Json?
  auditedAt            DateTime?
  error                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, level, topic, slotIndex])
  @@index([journeyId, level, topic])
  @@index([status])
  @@map("dp_journey_stories_v1")
}

model StudioConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("dp_studio_config_v1")
}

enum BillingSource {
  stripe
  google_play
}

enum BillingStatus {
  active
  trialing
  in_grace_period
  on_hold
  paused
  canceled
  expired
  pending
  revoked
  unknown
}

model Favorite {
  id              String    @id @default(cuid())
  userId          String
  word            String
  translation     String
  wordType        String?
  exampleSentence String?
  storySlug       String?
  storyTitle      String?
  sourcePath      String?
  language        String?
  createdAt       DateTime  @default(now())
  nextReviewAt    DateTime?
  lastReviewedAt  DateTime?
  streak          Int       @default(0)

  @@unique([userId, word], name: "userId_word")
  @@index([userId])
}

model LibraryBook {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  title     String
  coverUrl  String
  createdAt DateTime @default(now())

  @@unique([userId, bookId], name: "userId_bookId")
  @@index([userId])
}

model LibraryStory {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  title     String
  coverUrl  String
  bookId    String
  createdAt DateTime @default(now())

  @@unique([userId, storyId], name: "userId_storyId")
  @@index([userId])
}

// Word-level audio alignments for stories that live in the static
// catalog (`src/data/books/*.ts`), generated via Modal/aeneas (the same
// pipeline that powers `JourneyStory.audioWordTimings`). Stored by slug
// because the catalog is TS-static — there is no parent table to
// extend. Populated by `scripts/generateCatalogAudioTimings.ts`; served
// by `/api/mobile/audio-word-timings` when the journey lookup misses.
model CatalogStoryAudioTimings {
  slug              String   @id
  audioWordTimings  Json
  audioDurationSec  Float?
  updatedAt         DateTime @updatedAt
}

model ClaimToken {
  id             String    @id @default(cuid())
  token          String    @unique
  buyerEmail     String
  recipientEmail String?
  books          String[]
  redeemedBy     String?
  redeemedAt     DateTime?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  @@index([buyerEmail])
  @@index([recipientEmail])
  @@index([redeemedBy])
  @@index([createdAt])
  @@map("dp_claim_tokens_v1")
}

model UserStory {
  id            String   @id @default(cuid())
  userId        String
  title         String
  slug          String   @unique
  text          String
  vocab         Json
  audioUrl      String?
  audioSegments Json?
  audioFilename String?
  audioStatus   String   @default("pending")
  language      String
  variant       String?
  region        String?
  level         String
  cefrLevel     String?
  focus         String?
  topic         String
  public        Boolean  @default(true)
  coverUrl      String?
  coverFilename String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("dp_user_stories_v1")
}

model UserMetric {
  id        String   @id @default(cuid())
  userId    String
  bookSlug  String?
  storySlug String
  eventType String // "audio_play", "audio_pause", "audio_complete", "scroll", etc.
  value     Float?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([storySlug])
  @@index([createdAt])
  @@index([userId, eventType, createdAt])
  @@index([userId, storySlug, createdAt])
  @@map("dp_user_metrics_v1")
}

model ContinueListeningEntry {
  id               String   @id @default(cuid())
  userId           String
  bookSlug         String
  storySlug        String
  progressSec      Int?
  audioDurationSec Int?
  lastPlayedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, bookSlug, storySlug], name: "userId_bookSlug_storySlug")
  @@index([userId])
  @@index([lastPlayedAt])
  @@index([userId, lastPlayedAt])
  @@map("dp_continue_listening_v1")
}

model WeeklyMetricsSnapshot {
  id                String   @id @default(cuid())
  weekStart         DateTime
  weekEnd           DateTime
  totalPlays        Int
  totalCompletions  Int
  avgCompletionRate Float
  avgDuration       Float?
  createdAt         DateTime @default(now())

  @@index([weekStart])
  @@index([weekEnd])
  @@map("dp_weekly_metrics_v1")
}

model BillingEntitlement {
  id                     String        @id @default(cuid())
  userId                 String        @unique
  plan                   String
  source                 BillingSource
  status                 BillingStatus @default(unknown)
  productId              String?
  externalCustomerId     String?
  externalSubscriptionId String?
  purchaseToken          String?       @unique
  orderId                String?
  willRenew              Boolean       @default(false)
  startedAt              DateTime      @default(now())
  renewedAt              DateTime?
  trialEndsAt            DateTime?
  expiresAt              DateTime?
  rawPayload             Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([source, status])
  @@index([expiresAt])
  @@index([productId])
  @@map("dp_billing_entitlements_v1")
}

// Public catalog: target of the Sanity -> Studio migration.
// Each row mirrors a Book / Story from src/data/books (which itself mirrors
// the Sanity dataset). Treated as read-only from app code; writes happen via
// the scripts/migrateBookToStudioCatalog.ts ETL only.
//
// `id` is the slug (stable, human-readable) so the ETL can upsert by id.
model CatalogBook {
  id              String    @id
  slug            String    @unique
  title           String
  description     String    @default("")
  subtitle        String?
  cover           String    @default("/covers/default.jpg")
  theme           String[]  @default([])
  language        String
  variant         String?
  region          String?
  level           String
  cefrLevel       String?
  topic           String?
  formality       String?
  audioFolder     String    @default("")
  storeUrl        String?
  published       Boolean   @default(true)
  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  migratedFrom    String?
  sanityId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stories CatalogStory[]

  @@index([language, level])
  @@index([published])
  @@map("dp_catalog_books_v1")
}

// `id` is composed as `${bookId}:${storySlug}` so two books can share story
// slugs without collision, and so upserts are idempotent against the source.
model CatalogStory {
  id               String    @id
  bookId           String
  slug             String
  position         Int
  title            String
  text             String
  audio            String    @default("")
  cover            String?
  coverUrl         String?
  topic            String?
  tags             String[]  @default([])
  vocab            Json?
  language         String?
  variant          String?
  region           String?
  level            String?
  cefrLevel        String?
  formality        String?
  overrideMetadata Boolean   @default(false)
  sourceCreatedAt  DateTime?
  sourceUpdatedAt  DateTime?
  migratedFrom     String?
  sanityId         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  book CatalogBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, slug])
  @@index([bookId, position])
  @@map("dp_catalog_stories_v1")
}
