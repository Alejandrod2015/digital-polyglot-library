generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudioRole {
  admin
  manager
  content_creator
}

enum AgentKind {
  curriculum
  planner
  content
  qa
  translation
  validar
}

enum AgentRunStatus {
  queued
  running
  completed
  failed
  needs_review
}

enum AgentArtifactStatus {
  draft
  generated
  qa_pass
  qa_fail
  needs_review
  approved
  published
}

model Topic {
  id           String   @id @default(cuid())
  slug         String   @unique
  label        String
  isUniversal  Boolean  @default(true)
  defaultLevel String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journeyTypes TopicJourneyType[]

  @@index([sortOrder])
  @@map("dp_topics_v1")
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants LanguageVariant[]

  @@index([sortOrder])
  @@map("dp_languages_v1")
}

model LanguageVariant {
  id         String   @id @default(cuid())
  languageId String
  code       String
  label      String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([languageId, code])
  @@index([languageId])
  @@map("dp_language_variants_v1")
}

model Level {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("dp_levels_v1")
}

model JourneyType {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics TopicJourneyType[]

  @@index([sortOrder])
  @@map("dp_journey_types_v1")
}

model TopicJourneyType {
  id            String   @id @default(cuid())
  topicId       String
  journeyTypeId String
  createdAt     DateTime @default(now())

  topic       Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  journeyType JourneyType @relation(fields: [journeyTypeId], references: [id], onDelete: Cascade)

  @@unique([topicId, journeyTypeId])
  @@index([topicId])
  @@index([journeyTypeId])
  @@map("dp_topic_journey_types_v1")
}

model StudioMember {
  id        String     @id @default(cuid())
  email     String     @unique
  role      StudioRole
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("dp_studio_members")
}

model AgentRun {
  id           String         @id @default(cuid())
  agentKind    AgentKind
  status       AgentRunStatus @default(queued)
  model        String?
  input        Json
  output       Json?
  errorMessage String?
  toolsUsed    String[]
  parentRunId  String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([agentKind, status, createdAt])
  @@index([parentRunId])
  @@map("dp_agent_runs_v1")
}

model CurriculumBrief {
  id           String              @id @default(cuid())
  language     String
  variant      String
  level        String
  journeyKey   String
  topicSlug    String
  storySlot    Int
  journeyFocus String?             @default("General")
  title        String
  brief        Json
  status       AgentArtifactStatus @default(draft)
  sourceRunId  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([language, variant, level])
  @@index([journeyKey, topicSlug, storySlot])
  @@index([status])
  @@map("dp_curriculum_briefs_v1")
}

model StoryDraft {
  id            String              @id @default(cuid())
  briefId       String?
  sourceStoryId String?
  title         String
  slug          String?
  text          String
  synopsis      String?
  vocab         Json?
  metadata      Json?
  status        AgentArtifactStatus @default(draft)
  sourceRunId   String?
  latestQaRunId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([briefId])
  @@index([sourceStoryId])
  @@index([status])
  @@map("dp_story_drafts_v1")
}

model QAReview {
  id             String   @id @default(cuid())
  storyDraftId   String?
  sourceStoryId  String?
  sourceRunId    String?
  status         String
  score          Float?
  report         Json
  correctedText  String?
  correctedVocab Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([storyDraftId])
  @@index([sourceStoryId])
  @@index([status, createdAt])
  @@map("dp_qa_reviews_v1")
}

enum JourneyStatus {
  active
  completed
  archived
}

model ClonedVoice {
  id           String   @id @default(cuid())
  name         String
  language     String
  region       String?
  gender       String   @default("f")
  refAudioPath String
  refText      String
  createdBy    String?
  createdAt    DateTime @default(now())

  @@index([language])
  @@map("dp_cloned_voices_v1")
}

model Journey {
  id              String        @id @default(cuid())
  name            String
  language        String
  variant         String
  levels          String[]
  topics          String[]
  storiesPerTopic Int           @default(1)
  status          JourneyStatus @default(active)
  createdBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  stories JourneyStory[]

  @@index([status])
  @@index([language, variant])
  @@map("dp_journeys_v1")
}

model JourneyStory {
  id                   String              @id @default(cuid())
  journeyId            String
  level                String
  topic                String
  slotIndex            Int
  status               AgentArtifactStatus @default(draft)
  title                String?
  slug                 String?
  text                 String?
  synopsis             String?
  vocab                Json?
  wordCount            Int?
  vocabCount           Int?
  arcType              String?
  // Dialect/register asset metadata. All optional; backfilled by the
  // editorial workflow as content is tagged. Foundation for filtering
  // the corpus by register, cohort, or cultural variant.
  register             String[]            @default([])
  generationCohort     String?
  culturalTags         String[]            @default([])
  voiceProvenance      Json?
  sanityId             String?
  coverDone            Boolean             @default(false)
  coverUrl             String?
  audioUrl             String?
  audioSegments        Json?
  audioWordTimings     Json?
  audioFilename        String?
  audioStatus          String              @default("pending")
  audioUrlPreview      String?
  audioFilenamePreview String?
  ambientTag           String?
  voiceId              String?
  /// Voice override for the practice exercises' TTS. When null, the
  /// practice pipeline falls back to the per-language default (Paola
  /// for italian, Dora for spanish, Cadu for portuguese). Independent
  /// from `voiceId` (which is the narration voice for the full story).
  practiceVoiceId      String?
  dialogueSpec         Json?
  audioQaStatus        String?
  audioQaScore         Float?
  audioQaNotes         String?
  // Vocabulary-level audit (LLM-as-judge against story.level CEFR).
  // Cleared whenever text is regenerated; refilled by /audit-level.
  auditScore           Float?
  auditOffenders       Json?
  auditedAt            DateTime?
  error                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  practiceSet StoryPracticeSet?

  @@unique([journeyId, level, topic, slotIndex])
  @@index([journeyId, level, topic])
  @@index([status])
  @@map("dp_journey_stories_v1")
}

/// Editorially curated set of practice exercises for one JourneyStory.
/// One row per story (1:1). When present, the mobile end-of-story flow
/// reads from this set instead of generating exercises on the fly. Lets
/// us edit individual exercises in Studio without redeploying.
model StoryPracticeSet {
  id        String   @id @default(cuid())
  storyId   String   @unique
  story     JourneyStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  exercises StoryPracticeExercise[]
  /// When false, the seed script will overwrite this set the next time
  /// it runs. Set to true once an editor has reviewed/approved.
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dp_story_practice_sets_v1")
}

/// Individual exercise inside a StoryPracticeSet. `orderIndex` is the
/// position in the session (0..N-1, typically 0..9).
model StoryPracticeExercise {
  id         String   @id @default(cuid())
  setId      String
  set        StoryPracticeSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  orderIndex Int
  /// One of: fill_blank | meaning_in_context | listen_choose | natural_expression
  type       String
  /// Target vocab word (the right answer for fill_blank/natural, the
  /// prompt for meaning/listening).
  word       String
  /// Sentence shown on screen. For fill_blank this contains "_____".
  sentence   String
  /// Pre-rendered mp3 in R2 (clean Piper + 150 ms tail). Null until the
  /// audio job runs.
  audioUrl   String?
  /// `{ options: string[], answer: string }` for choice exercises;
  /// `{ pairs: [{word, meaning}], extras: string[] }` for match.
  payload    Json
  /// Whether this exercise appears on the end-of-story screen. The 10
  /// editor-approved ones are featured=true; the rest live in the pool
  /// and only surface in the Practice tab. Default true so the legacy
  /// 10-exercise sets behave identically pre/post migration.
  featured   Boolean  @default(true)
  /// Denormalized from JourneyStory.journey.language. Lets the Practice
  /// tab query the pool by language without 3-table joins. Nullable for
  /// resilience; backfilled at migration time.
  language   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([setId, orderIndex])
  @@index([setId])
  @@index([language])
  @@index([featured])
  @@index([word, language])
  @@map("dp_story_practice_exercises_v1")
}

model StudioConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("dp_studio_config_v1")
}

enum BillingSource {
  stripe
  google_play
}

enum BillingStatus {
  active
  trialing
  in_grace_period
  on_hold
  paused
  canceled
  expired
  pending
  revoked
