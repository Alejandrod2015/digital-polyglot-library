generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudioRole {
  admin
  manager
  content_creator
}

model StudioMember {
  id        String     @id @default(cuid())
  email     String     @unique
  role      StudioRole
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("dp_studio_members")
}

enum BillingSource {
  stripe
  google_play
}

enum BillingStatus {
  active
  trialing
  in_grace_period
  on_hold
  paused
  canceled
  expired
  pending
  revoked
  unknown
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  word        String
  translation String
  wordType    String?
  exampleSentence String?
  storySlug   String?
  storyTitle  String?
  sourcePath  String?
  language    String?
  createdAt   DateTime @default(now())
  nextReviewAt DateTime?
  lastReviewedAt DateTime?
  streak      Int      @default(0)

  @@index([userId])
  @@unique([userId, word], name: "userId_word")
}

model LibraryBook {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  title     String
  coverUrl  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, bookId], name: "userId_bookId")
}

model LibraryStory {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  title     String
  coverUrl  String
  bookId    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, storyId], name: "userId_storyId")
}

model ClaimToken {
  id             String    @id @default(cuid())
  token          String    @unique
  buyerEmail     String
  recipientEmail String?
  books          String[]
  redeemedBy     String?
  redeemedAt     DateTime?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  @@map("dp_claim_tokens_v1")
  @@index([buyerEmail])
  @@index([recipientEmail])
  @@index([redeemedBy])
  @@index([createdAt])
}

model UserStory {
  id            String   @id @default(cuid())
  userId        String
  title         String
  slug          String   @unique
  text          String
  vocab         Json
  audioUrl      String?
  audioSegments Json?
  audioFilename String?
  audioStatus   String   @default("pending")
  language      String
  variant       String?
  region        String?
  level         String
  cefrLevel     String?
  focus         String?
  topic         String
  public        Boolean  @default(true)
  coverUrl      String?
  coverFilename String?
  createdAt     DateTime @default(now())

  @@map("dp_user_stories_v1")
  @@index([userId])
  @@index([createdAt])
}

model UserMetric {
  id         String   @id @default(cuid())
  userId     String
  bookSlug   String?
  storySlug  String
  eventType  String   // "audio_play", "audio_pause", "audio_complete", "scroll", etc.
  value      Float?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@map("dp_user_metrics_v1")
  @@index([userId])
  @@index([storySlug])
  @@index([createdAt])
  @@index([userId, eventType, createdAt])
  @@index([userId, storySlug, createdAt])
}

model ContinueListeningEntry {
  id           String   @id @default(cuid())
  userId       String
  bookSlug     String
  storySlug    String
  progressSec  Int?
  audioDurationSec Int?
  lastPlayedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("dp_continue_listening_v1")
  @@unique([userId, bookSlug, storySlug], name: "userId_bookSlug_storySlug")
  @@index([userId])
  @@index([lastPlayedAt])
  @@index([userId, lastPlayedAt])
}

model WeeklyMetricsSnapshot {
  id             String   @id @default(cuid())
  weekStart      DateTime
  weekEnd        DateTime
  totalPlays     Int
  totalCompletions Int
  avgCompletionRate Float
  avgDuration    Float?
  createdAt      DateTime @default(now())

  @@map("dp_weekly_metrics_v1")
  @@index([weekStart])
  @@index([weekEnd])
}

model BillingEntitlement {
  id                     String        @id @default(cuid())
  userId                 String        @unique
  plan                   String
  source                 BillingSource
  status                 BillingStatus @default(unknown)
  productId              String?
  externalCustomerId     String?
  externalSubscriptionId String?
  purchaseToken          String?       @unique
  orderId                String?
  willRenew              Boolean       @default(false)
  startedAt              DateTime      @default(now())
  renewedAt              DateTime?
  trialEndsAt            DateTime?
  expiresAt              DateTime?
  rawPayload             Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@map("dp_billing_entitlements_v1")
  @@index([source, status])
  @@index([expiresAt])
  @@index([productId])
}
