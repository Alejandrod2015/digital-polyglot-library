// Public catalog: target of the Sanity -> Studio migration.
// Each row mirrors a Book / Story from src/data/books (which itself mirrors
// the Sanity dataset). Treated as read-only from app code; writes happen via
// the scripts/migrateBookToStudioCatalog.ts ETL only.
//
// `id` is the slug (stable, human-readable) so the ETL can upsert by id.
model CatalogBook {
  id              String    @id
  slug            String    @unique
  title           String
  description     String    @default("")
  subtitle        String?
  cover           String    @default("/covers/default.jpg")
  coverUrl        String?
  theme           String[]  @default([])
  language        String
  variant         String?
  region          String?
  level           String
  cefrLevel       String?
  topic           String?
  formality       String?
  audioFolder     String    @default("")
  storeUrl        String?
  published       Boolean   @default(true)
  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  migratedFrom    String?
  sanityId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stories CatalogStory[]

  @@index([language, level])
  @@index([published])
  @@map("dp_catalog_books_v1")
}

// `id` is composed as `${bookId}:${storySlug}` so two books can share story
// slugs without collision, and so upserts are idempotent against the source.
model CatalogStory {
  id               String    @id
  bookId           String
  slug             String
  position         Int
  title            String
  // Short editorial blurb used by the reader preview, social cards, and
  // SEO. Distinct from `text` (full body). Matches the `synopsis` field
  // that exists on JourneyStory + StandaloneStory; added to CatalogStory
  // in migration 20260518120000 so all three story models converge.
  synopsis         String?
  text             String
  audio            String    @default("")
  audioUrl         String?
  cover            String?
  coverUrl         String?
  topic            String?
  tags             String[]  @default([])
  vocab            Json?
  language         String?
  variant          String?
  region           String?
  level            String?
  cefrLevel        String?
  formality        String?
  overrideMetadata Boolean   @default(false)
  sourceCreatedAt  DateTime?
  sourceUpdatedAt  DateTime?
  migratedFrom     String?
  sanityId         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  book CatalogBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, slug])
  @@index([bookId, position])
  @@map("dp_catalog_stories_v1")
}

// Public standalone stories: target of the second wave of the
// Sanity -> Studio migration. Each row mirrors a `standaloneStory` document
// from Sanity. Unlike CatalogStory, these are not grouped under a book.
//
// `id` is the slug so the ETL can upsert by id. Editorial fields and QA
// reports are preserved as-is to keep the door open for re-implementing the
// Sanity editor inside Studio (Next.js) later.
model StandaloneStory {
  id                String    @id
  slug              String    @unique
  sourceType        String    @default("sanity")
  createStoryId     String?
  createStoryUserId String?
  language          String?
  variant           String?
  region            String?
  level             String?
  cefrLevel         String?
  focus             String?
  topic             String?
  journeyEligible   Boolean   @default(false)
  journeyTopic      String?
  journeyOrder      Int?
  journeyFocus      String?
  title             String
  synopsis          String?
  text              String    @default("")
  vocabRaw          String?
  vocab             Json?
  cover             String?
  coverUrl          String?
  audio             String?
  audioUrl          String?
  audioQaStatus            String?
  audioQaScore             Float?
  audioQaNotes             String?
  audioQaTranscript        String?
  audioQaCheckedAt         DateTime?
  audioDeliveryQaStatus    String?
  audioDeliveryQaScore     Float?
  audioDeliveryQaNotes     String?
  audioDeliveryQaCheckedAt DateTime?
  storyVocabQualityRaw     String?
  vocabValidationRaw       String?
  published         Boolean   @default(false)
  sanityId          String?
  migratedFrom      String?
  sourceCreatedAt   DateTime?
  sourceUpdatedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([language, level])
  @@index([cefrLevel])
  @@index([sourceType])
  @@index([journeyEligible, journeyTopic, journeyOrder])
  @@index([published])
  @@index([sanityId])
  @@map("dp_standalone_stories_v1")
}
