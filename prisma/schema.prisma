generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudioRole {
  admin
  manager
  content_creator
}

enum AgentKind {
  curriculum
  planner
  content
  qa
  translation
}

enum AgentRunStatus {
  queued
  running
  completed
  failed
  needs_review
}

enum AgentArtifactStatus {
  draft
  generated
  qa_pass
  qa_fail
  needs_review
  approved
  published
}

model Topic {
  id           String   @id @default(cuid())
  slug         String   @unique
  label        String
  isUniversal  Boolean  @default(true)
  defaultLevel String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journeyTypes TopicJourneyType[]

  @@map("dp_topics_v1")
  @@index([sortOrder])
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants LanguageVariant[]

  @@map("dp_languages_v1")
  @@index([sortOrder])
}

model LanguageVariant {
  id         String   @id @default(cuid())
  languageId String
  code       String
  label      String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@map("dp_language_variants_v1")
  @@unique([languageId, code])
  @@index([languageId])
}

model Level {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dp_levels_v1")
  @@index([sortOrder])
}

model JourneyType {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics TopicJourneyType[]

  @@map("dp_journey_types_v1")
  @@index([sortOrder])
}

model TopicJourneyType {
  id            String      @id @default(cuid())
  topicId       String
  journeyTypeId String
  createdAt     DateTime    @default(now())

  topic       Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  journeyType JourneyType @relation(fields: [journeyTypeId], references: [id], onDelete: Cascade)

  @@unique([topicId, journeyTypeId])
  @@map("dp_topic_journey_types_v1")
  @@index([topicId])
  @@index([journeyTypeId])
}

model StudioMember {
  id        String     @id @default(cuid())
  email     String     @unique
  role      StudioRole
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("dp_studio_members")
}

model AgentRun {
  id           String         @id @default(cuid())
  agentKind    AgentKind
  status       AgentRunStatus @default(queued)
  model        String?
  input        Json
  output       Json?
  errorMessage String?
  toolsUsed    String[]
  parentRunId  String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("dp_agent_runs_v1")
  @@index([agentKind, status, createdAt])
  @@index([parentRunId])
}

model CurriculumBrief {
  id            String              @id @default(cuid())
  language      String
  variant       String
  level         String
  journeyKey    String
  topicSlug     String
  storySlot     Int
  journeyFocus  String?             @default("General")
  title         String
  brief         Json
  status        AgentArtifactStatus @default(draft)
  sourceRunId   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("dp_curriculum_briefs_v1")
  @@index([language, variant, level])
  @@index([journeyKey, topicSlug, storySlot])
  @@index([status])
}

model StoryDraft {
  id               String              @id @default(cuid())
  briefId          String?
  sourceStoryId    String?
  title            String
  slug             String?
  text             String
  synopsis         String?
  vocab            Json?
  metadata         Json?
  status           AgentArtifactStatus @default(draft)
  sourceRunId      String?
  latestQaRunId    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@map("dp_story_drafts_v1")
  @@index([briefId])
  @@index([sourceStoryId])
  @@index([status])
}

model QAReview {
  id                String   @id @default(cuid())
  storyDraftId      String?
  sourceStoryId     String?
  sourceRunId       String?
  status            String
  score             Float?
  report            Json
  correctedText     String?
  correctedVocab    Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("dp_qa_reviews_v1")
  @@index([storyDraftId])
  @@index([sourceStoryId])
  @@index([status, createdAt])
}

enum JourneyStatus {
  active
  completed
  archived
}

model Journey {
  id              String        @id @default(cuid())
  name            String
  language        String
  variant         String
  levels          String[]
  topics          String[]
  storiesPerTopic Int           @default(1)
  status          JourneyStatus @default(active)
  createdBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  stories JourneyStory[]

  @@map("dp_journeys_v1")
  @@index([status])
  @@index([language, variant])
}

model JourneyStory {
  id         String              @id @default(cuid())
  journeyId  String
  level      String
  topic      String
  slotIndex  Int
  status     AgentArtifactStatus @default(draft)
  title      String?
  slug       String?
  text       String?
  synopsis   String?
  vocab      Json?
  wordCount  Int?
  vocabCount Int?
  sanityId   String?
  coverDone     Boolean             @default(false)
  coverUrl      String?
  audioUrl      String?
  audioSegments Json?
  audioFilename String?
  audioStatus   String              @default("pending")
  error         String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@map("dp_journey_stories_v1")
  @@index([journeyId, level, topic])
  @@index([status])
  @@unique([journeyId, level, topic, slotIndex])
}

model StudioConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("dp_studio_config_v1")
}

enum BillingSource {
  stripe
  google_play
}

enum BillingStatus {
  active
  trialing
  in_grace_period
  on_hold
  paused
  canceled
  expired
  pending
  revoked
  unknown
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  word        String
  translation String
  wordType    String?
  exampleSentence String?
  storySlug   String?
  storyTitle  String?
  sourcePath  String?
  language    String?
  createdAt   DateTime @default(now())
  nextReviewAt DateTime?
  lastReviewedAt DateTime?
  streak      Int      @default(0)

  @@index([userId])
  @@unique([userId, word], name: "userId_word")
}

model LibraryBook {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  title     String
  coverUrl  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, bookId], name: "userId_bookId")
}

model LibraryStory {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  title     String
  coverUrl  String
  bookId    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, storyId], name: "userId_storyId")
}

model ClaimToken {
  id             String    @id @default(cuid())
  token          String    @unique
  buyerEmail     String
  recipientEmail String?
  books          String[]
  redeemedBy     String?
  redeemedAt     DateTime?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  @@map("dp_claim_tokens_v1")
  @@index([buyerEmail])
  @@index([recipientEmail])
  @@index([redeemedBy])
  @@index([createdAt])
}

model UserStory {
  id            String   @id @default(cuid())
  userId        String
  title         String
  slug          String   @unique
  text          String
  vocab         Json
  audioUrl      String?
  audioSegments Json?
  audioFilename String?
  audioStatus   String   @default("pending")
  language      String
  variant       String?
  region        String?
  level         String
  cefrLevel     String?
  focus         String?
  topic         String
  public        Boolean  @default(true)
  coverUrl      String?
  coverFilename String?
  createdAt     DateTime @default(now())

  @@map("dp_user_stories_v1")
  @@index([userId])
  @@index([createdAt])
}

model UserMetric {
  id         String   @id @default(cuid())
  userId     String
  bookSlug   String?
  storySlug  String
  eventType  String   // "audio_play", "audio_pause", "audio_complete", "scroll", etc.
  value      Float?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@map("dp_user_metrics_v1")
  @@index([userId])
  @@index([storySlug])
  @@index([createdAt])
  @@index([userId, eventType, createdAt])
  @@index([userId, storySlug, createdAt])
}

model ContinueListeningEntry {
  id           String   @id @default(cuid())
  userId       String
  bookSlug     String
  storySlug    String
  progressSec  Int?
  audioDurationSec Int?
  lastPlayedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("dp_continue_listening_v1")
  @@unique([userId, bookSlug, storySlug], name: "userId_bookSlug_storySlug")
  @@index([userId])
  @@index([lastPlayedAt])
  @@index([userId, lastPlayedAt])
}

model WeeklyMetricsSnapshot {
  id             String   @id @default(cuid())
  weekStart      DateTime
  weekEnd        DateTime
  totalPlays     Int
  totalCompletions Int
  avgCompletionRate Float
  avgDuration    Float?
  createdAt      DateTime @default(now())

  @@map("dp_weekly_metrics_v1")
  @@index([weekStart])
  @@index([weekEnd])
}

model BillingEntitlement {
  id                     String        @id @default(cuid())
  userId                 String        @unique
  plan                   String
  source                 BillingSource
  status                 BillingStatus @default(unknown)
  productId              String?
  externalCustomerId     String?
  externalSubscriptionId String?
  purchaseToken          String?       @unique
  orderId                String?
  willRenew              Boolean       @default(false)
  startedAt              DateTime      @default(now())
  renewedAt              DateTime?
  trialEndsAt            DateTime?
  expiresAt              DateTime?
  rawPayload             Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@map("dp_billing_entitlements_v1")
  @@index([source, status])
  @@index([expiresAt])
  @@index([productId])
}
