{
  "name": "@digital-polyglot/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "expo": {
    "autolinking": {
      "exclude": [
        "@clerk/expo"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
